#! /usr/bin/bash

set -euo pipefail

mode="${1:-debug}"

case "${mode}" in
    debug)
        cargo_args=(build --workspace)
        target_dir="debug"
        ;;
    release)
        cargo_args=(build --workspace --release)
        target_dir="release"
        ;;
    -h|--help|help)
        echo "Usage: dev/rebuild [debug|release]"
        echo "  debug    Build workspace debug binaries (default)"
        echo "  release  Build workspace release binaries"
        exit 0
        ;;
    *)
        echo "error: unknown rebuild mode '${mode}'" >&2
        echo "Usage: dev/rebuild [debug|release]" >&2
        exit 2
        ;;
esac

# Build eBPF redirect program (excluded from workspace, requires nightly)
# The compiled ELF is embedded into the network crate via include_bytes!()
# Must cd into the crate so cargo picks up .cargo/config.toml (target + build-std)
echo "Building eBPF redirect program..."
(cd crates/ebpf-redirect && cargo +nightly build --release)
cp crates/ebpf-redirect/target/bpfel-unknown-none/release/ebpf-redirect crates/ebpf-redirect/ebpf-redirect.elf

# Build Tailwind CSS (embedded into sherpad binary at compile time)
bash scripts/tailwind-build.sh

# Build workspace binaries only. Do not use --all-targets here: it compiles test
# targets such as sherpad(test), which are not installed by this script.
echo "Building Sherpa workspace (${mode})..."
cargo "${cargo_args[@]}"
sudo systemctl stop sherpad
sudo cp "target/${target_dir}/sherpad" /opt/sherpa/bin/
sudo cp "target/${target_dir}/sherpa" /opt/sherpa/bin/
sudo systemctl restart sherpad
