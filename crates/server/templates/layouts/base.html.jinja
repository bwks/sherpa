<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Sherpa Labs{% endblock %}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">

    <!-- Tailwind CSS -->
    <link rel="stylesheet" href="/css/tailwind.css">

    <!-- Theme (must load before body renders to prevent flash) -->
    <script src="/js/theme.js"></script>

    <!-- HTMX -->
    <script src="/js/htmx-2.0.8.min.js"></script>
    <script src="/js/htmx-ext-sse-2.2.4.min.js"></script>

    <!-- Custom Styles -->
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="bg-page min-h-screen">
    <!-- Sidebar -->
    {% include "snippets/sidebar.html.jinja" %}

    <!-- Main Content -->
    <main class="ml-60 min-h-screen px-8 py-8">
        {% block content %}{% endblock %}
    </main>
</body>
</html>
