{# Node state badge (small — for table rows) #}
{% macro node_state(state) %}
    {% if state.to_string() == "running" %}
    <span class="badge-success">Running</span>
    {% elif state.to_string() == "created" || state.to_string() == "starting" %}
    <span class="badge-warning">{{ state.to_string()|capitalize }}</span>
    {% elif state.to_string() == "failed" %}
    <span class="badge-danger">Failed</span>
    {% else %}
    <span class="badge-neutral">{{ state.to_string()|capitalize }}</span>
    {% endif %}
{% endmacro %}

{# Node state badge (large — for detail page headers) #}
{% macro node_state_lg(state) %}
    {% if state.to_string() == "running" %}
