{% import "macros/icons.html.jinja" as icons %}
<h2 class="text-xl font-semibold text-heading mb-4">
    Nodes
    <span class="text-base font-normal text-muted">
        ({{ device_count }} total)
    </span>
</h2>

{% if device_count > 0 %}
<div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-border">
        <thead class="bg-table-head">
            <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                    Name
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                    Model
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                    Type
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                    State
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                    Mgmt IPv4
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                    Mgmt IPv6
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                    VNC Port
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                    Disks
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                    Actions
                </th>
            </tr>
        </thead>
        <tbody class="bg-card divide-y divide-border">
            {% for device in devices %}
            <tr class="hover:bg-hover transition-colors" id="node-row-{{ device.name }}">
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <a href="/labs/{{ lab_id }}/nodes/{{ device.name }}" class="text-accent hover:text-accent-hover hover:underline">
                        {{ device.name }}
                    </a>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-body font-mono">
                    {{ device.model }}
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-body font-mono">
                    {{ device.kind }}
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                    {% if device.state.to_string() == "running" %}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-success text-success-text">
                        Running
                    </span>
                    {% elif device.state.to_string() == "created" || device.state.to_string() == "starting" %}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-warning text-warning-text">
                        {{ device.state.to_string()|capitalize }}
                    </span>
                    {% elif device.state.to_string() == "failed" %}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-danger text-danger-text">
                        Failed
                    </span>
                    {% else %}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-neutral-badge text-neutral-badge-text">
                        {{ device.state.to_string()|capitalize }}
                    </span>
                    {% endif %}
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-body font-mono">
                    {% if device.mgmt_ipv4 != "" %}{{ device.mgmt_ipv4 }}{% else %}-{% endif %}
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-body font-mono">
                    {% if let Some(ipv6) = device.mgmt_ipv6 %}{{ ipv6 }}{% else %}-{% endif %}
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-body font-mono">
                    {% if let Some(port) = device.vnc_port %}{{ port }}{% else %}-{% endif %}
                </td>
                <td class="px-6 py-4 text-sm text-body font-mono">
                    {% if device.disks.is_empty() %}-{% else %}{{ device.disks.join(", ") }}{% endif %}
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm">
                    <div class="flex items-center space-x-2">
                        {% if device.state.to_string() == "running" %}
                        <button
                            onclick="nodeAction('{{ lab_id }}', '{{ device.name }}', 'stop', this)"
                            class="text-danger-solid hover:text-danger-solid-hover transition-colors cursor-pointer"
                            title="Stop node">
                            {% call icons::stop() %}
                        </button>
                        {% else %}
                        <button
                            onclick="nodeAction('{{ lab_id }}', '{{ device.name }}', 'start', this)"
                            class="text-accent hover:text-accent-hover transition-colors cursor-pointer"
                            title="Start node">
                            {% call icons::play() %}
                        </button>
                        {% endif %}
                        <button
                            onclick="nodeRedeploy('{{ lab_id }}', '{{ device.name }}', this)"
                            class="text-edit hover:text-edit-hover transition-colors cursor-pointer"
                            title="Redeploy node">
                            {% call icons::redeploy() %}
                        </button>
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% else %}
<p class="text-center text-muted py-8 italic">No devices configured in this lab.</p>
{% endif %}
