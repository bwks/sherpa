<div class="bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg p-6 max-h-[400px] overflow-y-auto" hx-ext="sse" sse-connect="/labs/{{ lab_id }}/destroy/stream">
