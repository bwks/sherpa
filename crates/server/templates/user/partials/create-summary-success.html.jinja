<div class="mt-4 p-4 bg-card border border-border rounded-lg">
    <div class="flex items-center space-x-2 mb-3">
        <span class="text-2xl">&#x2705;</span>
        <h3 class="text-lg font-semibold text-alert-success-text">Lab "{{ lab_name }}" created successfully</h3>
    </div>
    <div class="text-sm text-muted mb-4">
        <p>Containers: {{ containers }} &middot; VMs: {{ vms }} &middot; Unikernels: {{ unikernels }} &middot; Networks: {{ networks }} &middot; Bridges: {{ bridges }} &middot; Interfaces: {{ interfaces }}</p>
        <p class="mt-1">Total time: {{ total_time_secs }}s</p>
    </div>
    <a href="/labs/{{ lab_id }}" class="px-4 py-2 text-sm font-medium text-white bg-accent rounded-lg hover:bg-accent-hover transition-colors inline-block">
        View Lab
    </a>
</div>
