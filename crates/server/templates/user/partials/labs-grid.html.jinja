{% import "macros/icons.html.jinja" as icons %}
{% import "macros/badges.html.jinja" as badges %}
<div class="bg-card rounded-lg shadow-sm border border-border overflow-hidden">
    <table class="w-full bg-card border-collapse">
        <thead class="bg-table-head border-b border-border">
            <tr>
                <th class="px-4 py-3 text-left text-xs font-semibold text-table-head-text uppercase tracking-wide">Name</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-table-head-text uppercase tracking-wide">Lab ID</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-table-head-text uppercase tracking-wide">Status</th>
                <th class="px-4 py-3 text-center text-xs font-semibold text-table-head-text uppercase tracking-wide">Nodes</th>
                <th class="px-4 py-3 text-right text-xs font-semibold text-table-head-text uppercase tracking-wide">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for lab in labs %}
            <tr class="border-b border-border last:border-b-0 hover:bg-hover transition-colors" id="lab-row-{{ lab.id }}">
                <td class="p-4 text-sm font-medium"><a href="/labs/{{ lab.id }}" class="text-accent hover:text-accent-hover hover:underline">{{ lab.name }}</a></td>
                <td class="p-4 text-sm text-muted font-mono">{{ lab.id }}</td>
                <td class="p-4 text-sm">
                    {% call badges::lab_state(lab.status) %}
                </td>
                <td class="p-4 text-sm text-body text-center">{{ lab.node_count }}</td>
                <td class="p-4 text-sm text-body">
                    <div class="flex items-center justify-end space-x-2">
                        {% match lab.status %}
                            {% when LabState::Running %}
                            <button
                                onclick="labStop('{{ lab.id }}', this)"
                                class="text-danger-solid hover:text-danger-solid-hover transition-colors cursor-pointer"
                                title="Stop all nodes">
                                {% call icons::stop() %}
                            </button>
                            {% when LabState::Partial %}
                            <button
                                onclick="labStart('{{ lab.id }}', this)"
                                class="text-accent hover:text-accent-hover transition-colors cursor-pointer"
                                title="Start all nodes">
                                {% call icons::play() %}
                            </button>
                            <button
                                onclick="labStop('{{ lab.id }}', this)"
                                class="text-danger-solid hover:text-danger-solid-hover transition-colors cursor-pointer"
                                title="Stop all nodes">
                                {% call icons::stop() %}
                            </button>
                            {% when LabState::Starting %}
                            <button
                                onclick="labStop('{{ lab.id }}', this)"
                                class="text-danger-solid hover:text-danger-solid-hover transition-colors cursor-pointer"
                                title="Stop all nodes">
                                {% call icons::stop() %}
                            </button>
                            {% else %}
                            <button
                                onclick="labStart('{{ lab.id }}', this)"
                                class="text-accent hover:text-accent-hover transition-colors cursor-pointer"
                                title="Start all nodes">
                                {% call icons::play() %}
                            </button>
                        {% endmatch %}
                        <a href="/labs/{{ lab.id }}" class="text-muted hover:text-heading transition-colors" title="View">
                            {% call icons::eye() %}
                        </a>
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
<script src="/js/lab-actions.js"></script>
