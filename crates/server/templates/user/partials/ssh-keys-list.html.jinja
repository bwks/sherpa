<div id="ssh-keys-list">
    {% if ssh_keys.is_empty() %}
    <p class="text-center text-muted text-sm py-8 bg-surface rounded-md mt-4">No SSH keys added yet.</p>
    {% else %}
    <div class="flex flex-col gap-3 mt-6">
        {% for ssh_key in ssh_keys %}
        <div class="flex items-center justify-between gap-4 p-4 bg-surface border border-border rounded-md">
            <div class="flex-1 overflow-hidden">
                <code class="block font-mono text-xs text-body whitespace-nowrap overflow-hidden text-ellipsis bg-card p-2 rounded border border-border">{{ ssh_key }}</code>
            </div>
            <button
                class="btn-danger-sm"
                hx-delete="/profile/ssh-keys/{{ loop.index0 }}"
                hx-target="#ssh-keys-list"
                hx-swap="outerHTML"
                hx-confirm="Are you sure you want to delete this SSH key?">
                Delete
            </button>
        </div>
        {% endfor %}
    </div>
    {% endif %}
</div>
