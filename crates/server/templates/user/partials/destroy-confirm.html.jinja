<div class="bg-alert-error border border-alert-error-border rounded-lg p-6">
    <div class="flex items-start space-x-3 mb-4">
        <span class="text-2xl">&#9888;&#65039;</span>
        <div>
            <h3 class="text-lg font-semibold text-alert-error-text">Destroy Lab "{{ lab_name }}"?</h3>
            <p class="text-sm text-muted mt-1">
                This will permanently destroy <strong>{{ device_count }}</strong> device(s) and all associated resources
                (networks, disks, interfaces, database records, and lab files).
            </p>
            <p class="text-sm text-danger-text font-medium mt-2">This action cannot be undone.</p>
        </div>
    </div>
    <div class="flex space-x-3">
        <button
            hx-post="/labs/{{ lab_id }}/destroy"
            hx-target="#destroy-action"
            hx-swap="innerHTML"
            class="btn-danger"
        >
            Confirm Destroy
        </button>
        <button
            hx-get="/labs/{{ lab_id }}/destroy/button"
            hx-target="#destroy-action"
            hx-swap="innerHTML"
            class="btn-cancel"
        >
            Cancel
        </button>
    </div>
</div>
