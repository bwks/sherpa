{% import "macros/icons.html.jinja" as icons %}
<div class="bg-card rounded-lg shadow-sm border border-border p-6 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
    <!-- Header -->
    <div class="flex items-start justify-between mb-4">
        <div class="flex-1">
            <h3 class="text-lg font-semibold text-heading">{{ lab.name }}</h3>
            <p class="text-sm text-muted font-mono">{{ lab.id }}</p>
        </div>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wide bg-neutral-badge text-neutral-badge-text">{{ lab.status }}</span>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 gap-3 mb-4">
        <div class="flex items-center space-x-2">
            <svg class="w-5 h-5 text-subtle" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path>
            </svg>
            <span class="text-sm text-muted">
                <span class="font-medium text-heading">{{ lab.node_count }}</span> nodes
            </span>
        </div>
    </div>

    <!-- Actions -->
    <div class="flex items-center space-x-3 pt-4 border-t border-border">
        <a href="/labs/{{ lab.id }}" class="flex-1 px-3 py-2 text-sm font-medium text-accent-lt-txt bg-accent-light rounded-md hover:bg-accent-light transition-colors text-center">
            View
        </a>
        <button onclick="labStart('{{ lab.id }}', this)" class="text-accent hover:text-accent-hover transition-colors cursor-pointer" title="Start all nodes">
            {% call icons::play() %}
        </button>
        <button onclick="labStop('{{ lab.id }}', this)" class="text-danger-solid hover:text-danger-solid-hover transition-colors cursor-pointer" title="Stop all nodes">
            {% call icons::stop() %}
        </button>
    </div>
</div>
