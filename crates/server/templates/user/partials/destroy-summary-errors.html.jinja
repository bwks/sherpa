<div class="mt-4 p-4 bg-card border border-border rounded-lg">
    <div class="flex items-center space-x-2 mb-3">
        <span class="text-2xl">&#x26A0;&#xFE0F;</span>
        <h3 class="text-lg font-semibold text-warning-text">Lab "{{ lab_name }}" destroyed with errors</h3>
    </div>
    <ul class="mb-4 space-y-1">
        {% for error in errors %}
        <li class="text-sm text-danger-text">&#x274C; [{{ error.resource_type }}] {{ error.resource_name }}: {{ error.error_message }}</li>
        {% endfor %}
    </ul>
    <a href="/" class="btn-primary">
        Back to Dashboard
    </a>
</div>
