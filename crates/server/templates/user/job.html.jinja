{% extends "layouts/base.html.jinja" %}

{% block title %}{{ action }} - {{ lab_name }}{% endblock %}

{% block content %}
<div class="max-w-4xl">
    <!-- Breadcrumb -->
    <nav class="text-sm text-muted mb-6">
        <a href="/" class="hover:text-heading transition-colors">Dashboard</a>
        <span class="mx-2">/</span>
        <span class="text-heading">{{ action }} Lab</span>
    </nav>

    <!-- Progress Container -->
    <div class="bg-surface border border-border rounded-lg p-6" hx-ext="sse" sse-connect="/jobs/{{ job_id }}/stream" sse-close="complete">
        <h3 class="text-lg font-semibold text-heading mb-3">{{ action }} Lab "{{ lab_name }}"...</h3>
        <div id="job-progress-lines" class="max-h-[400px] overflow-y-auto" sse-swap="progress" hx-swap="beforeend"></div>
        <div sse-swap="complete" hx-swap="innerHTML"></div>
    </div>
</div>
{% endblock %}
