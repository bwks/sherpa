{% extends "layouts/base.html.jinja" %}

{% block title %}Dashboard - Sherpa Labs{% endblock %}

{% block content %}
    <div class="space-y-6">
        <!-- Page Header -->
        <div>
            <h2 class="text-3xl font-bold text-heading">Dashboard</h2>
            <p class="mt-1 text-sm text-muted">Welcome back, {{ username }}</p>
        </div>

        <!-- Stats Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-card rounded-lg shadow-sm border border-border p-5">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-muted">My Labs</p>
                        <p class="mt-1 text-2xl font-bold text-heading">{{ lab_count }}</p>
                    </div>
                    <div class="p-3 bg-accent-light rounded-lg">
                        <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7m0 0h.375a2.625 2.625 0 0 1 0 5.25H3.375a2.625 2.625 0 0 1 0-5.25H4.5"/>
                        </svg>
                    </div>
                </div>
            </div>
            <div class="bg-card rounded-lg shadow-sm border border-border p-5">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-muted">Node Images</p>
                        <p class="mt-1 text-2xl font-bold text-heading">{{ image_count }}</p>
                    </div>
                    <div class="p-3 bg-accent-light rounded-lg">
                        <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m20.25 7.5-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5m8.25 3v6.75m0 0-3-3m3 3 3-3M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z"/>
                        </svg>
                    </div>
                </div>
            </div>
        </div>

        <!-- System Status -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="bg-card rounded-lg shadow-sm border border-border p-4 flex items-center gap-3">
                {% if docker_ok %}
                <span class="w-2.5 h-2.5 rounded-full bg-success-text flex-shrink-0"></span>
                {% else %}
                <span class="w-2.5 h-2.5 rounded-full bg-danger-solid flex-shrink-0"></span>
                {% endif %}
                <div>
                    <p class="text-sm font-medium text-body">Docker</p>
                    <p class="text-xs text-muted">{% if docker_ok %}Connected{% else %}Unavailable{% endif %}</p>
                </div>
            </div>
            <div class="bg-card rounded-lg shadow-sm border border-border p-4 flex items-center gap-3">
                {% if libvirt_ok %}
                <span class="w-2.5 h-2.5 rounded-full bg-success-text flex-shrink-0"></span>
                {% else %}
                <span class="w-2.5 h-2.5 rounded-full bg-danger-solid flex-shrink-0"></span>
                {% endif %}
                <div>
                    <p class="text-sm font-medium text-body">Libvirt</p>
                    <p class="text-xs text-muted">{% if libvirt_ok %}Connected{% else %}Unavailable{% endif %}</p>
                </div>
            </div>
            <div class="bg-card rounded-lg shadow-sm border border-border p-4 flex items-center gap-3">
                <span class="w-2.5 h-2.5 rounded-full bg-success-text flex-shrink-0"></span>
                <div>
                    <p class="text-sm font-medium text-body">Database</p>
                    <p class="text-xs text-muted">Connected</p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
