{% extends "layouts/base.html.jinja" %}

{% block title %}Labs - Sherpa Labs{% endblock %}

{% block content %}
    <div class="space-y-6">
        <!-- Page Header -->
        <div class="flex items-center justify-between">
            <div>
                <h2 class="text-3xl font-bold text-heading">Labs</h2>
                <p class="mt-1 text-sm text-muted">Manage your virtual machines, containers, and unikernels</p>
            </div>
            <a href="/labs/create" class="px-4 py-2 bg-accent text-white rounded-lg hover:bg-accent-hover transition-colors shadow-sm">
                Create New Lab
            </a>
        </div>

        <!-- Labs Container (HTMX target) -->
        <div id="labs-container"
             hx-get="/labs/grid"
             hx-trigger="load, every 30s">
            <!-- Labs will be loaded here by HTMX -->
        </div>
    </div>
{% endblock %}
