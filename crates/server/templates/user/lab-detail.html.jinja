{% extends "layouts/base.html.jinja" %}
{% import "macros/icons.html.jinja" as icons %}
{% import "macros/badges.html.jinja" as badges %}

{% block title %}{{ lab_info.name }} - Lab Details{% endblock %}


{% block content %}
<!-- Breadcrumb Navigation -->
<nav class="flex items-center mb-6 text-sm text-muted">
    <a href="/" class="text-accent hover:text-accent-hover hover:underline">Dashboard</a>
    <span class="mx-2">/</span>
    <a href="/labs" class="text-accent hover:text-accent-hover hover:underline">Labs</a>
    <span class="mx-2">/</span>
    <span class="text-heading font-medium">{{ lab_info.name }}</span>
</nav>

<!-- Lab Metadata Card -->
<div class="bg-card rounded-lg shadow-sm border border-border p-6 mb-6">
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-semibold text-heading">Lab Information</h2>
        {% match lab_state %}
            {% when LabState::Unknown %}
            {% when LabState::Empty %}
            {% else %}
            <a href="/labs/{{ lab_info.id }}/download" hx-boost="false" class="text-muted hover:text-heading transition-colors" title="Download lab files for CLI use">
                {% call icons::download() %}
            </a>
        {% endmatch %}
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="flex flex-col gap-1">
            <span class="block text-sm font-medium text-muted mb-1">Name</span>
            <span class="block text-base text-heading font-mono">{{ lab_info.name }}</span>
        </div>
        <div class="flex flex-col gap-1">
            <span class="block text-sm font-medium text-muted mb-1">ID</span>
            <span class="block text-base text-heading font-mono">{{ lab_info.id }}</span>
        </div>
        <div class="flex flex-col gap-1">
            <span class="block text-sm font-medium text-muted mb-1">Owner</span>
            <span class="block text-base text-heading font-mono">{{ lab_info.user }}</span>
        </div>
        <div class="flex flex-col gap-1">
            <span class="block text-sm font-medium text-muted mb-1">Management Network</span>
            <span class="block text-base text-heading font-mono">{{ lab_info.ipv4_network }}</span>
        </div>
        <div class="flex flex-col gap-1">
            <span class="block text-sm font-medium text-muted mb-1">IPv4 Gateway</span>
            <span class="block text-base text-heading font-mono">{{ lab_info.ipv4_gateway }}</span>
        </div>
        <div class="flex flex-col gap-1">
            <span class="block text-sm font-medium text-muted mb-1">IPv4 Router</span>
            <span class="block text-base text-heading font-mono">{{ lab_info.ipv4_router }}</span>
        </div>
        <div class="flex flex-col gap-1">
            <span class="block text-sm font-medium text-muted mb-1">State</span>
            <span class="block text-base">{% call badges::lab_state_lg(lab_state) %}</span>
        </div>
        <div class="flex flex-col gap-1">
            <span class="block text-sm font-medium text-muted mb-1">Loopback Network</span>
            <span class="block text-base text-heading font-mono">{{ lab_info.loopback_network }}</span>
        </div>
        {% if let Some(ipv6_network) = lab_info.ipv6_network %}
        <div class="flex flex-col gap-1">
            <span class="block text-sm font-medium text-muted mb-1">IPv6 Management Network</span>
            <span class="block text-base text-heading font-mono">{{ ipv6_network }}</span>
        </div>
        {% endif %}
        {% if let Some(ipv6_gateway) = lab_info.ipv6_gateway %}
        <div class="flex flex-col gap-1">
            <span class="block text-sm font-medium text-muted mb-1">IPv6 Gateway</span>
            <span class="block text-base text-heading font-mono">{{ ipv6_gateway }}</span>
        </div>
        {% endif %}
        {% if let Some(ipv6_router) = lab_info.ipv6_router %}
        <div class="flex flex-col gap-1">
            <span class="block text-sm font-medium text-muted mb-1">IPv6 Router</span>
            <span class="block text-base text-heading font-mono">{{ ipv6_router }}</span>
        </div>
        {% endif %}
    </div>
</div>

<!-- Nodes Section -->
<div class="bg-card rounded-lg shadow-sm border border-border p-6">
    <div id="nodes-table" hx-get="/labs/{{ lab_info.id }}/nodes" hx-trigger="every 60s" hx-swap="innerHTML">
        {% include "user/partials/nodes-table.html.jinja" %}
    </div>
</div>

<!-- Inactive Nodes Section -->
{% if inactive_device_count > 0 %}
<div class="bg-card rounded-lg shadow-sm border border-border p-6 mt-6">
    <h2 class="text-xl font-semibold text-heading mb-4">
        Inactive Nodes
        <span class="text-base font-normal text-muted">
            ({{ inactive_device_count }} total)
        </span>
    </h2>
    <div class="flex flex-wrap gap-2">
        {% for device_name in inactive_devices %}
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-neutral-badge text-neutral-badge-text font-mono">
            {{ device_name }}
        </span>
        {% endfor %}
    </div>
</div>
{% endif %}

<!-- Links Section -->
<div class="bg-card rounded-lg shadow-sm border border-border p-6 mt-6">
    <h2 class="text-xl font-semibold text-heading mb-4">
        Links
        <span class="text-base font-normal text-muted">
            ({{ link_count }} total)
        </span>
    </h2>

    {% if link_count > 0 %}
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-border">
            <thead class="bg-table-head">
                <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                        Node A
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                        Interface A
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                        Node B
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                        Interface B
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                        Type
                    </th>
                </tr>
            </thead>
            <tbody class="bg-card divide-y divide-border">
                {% for link in links %}
                <tr class="hover:bg-hover transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-heading">
                        {{ link.node_a_name }}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-body font-mono">
                        {{ link.int_a }}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-heading">
                        {{ link.node_b_name }}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-body font-mono">
                        {{ link.int_b }}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-body font-mono">
                        {{ link.kind }}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <p class="text-center text-muted py-8 italic">No links configured in this lab.</p>
    {% endif %}
</div>

<!-- Bridges Section -->
<div class="bg-card rounded-lg shadow-sm border border-border p-6 mt-6">
    <h2 class="text-xl font-semibold text-heading mb-4">
        Bridges
        <span class="text-base font-normal text-muted">
            ({{ bridge_count }} total)
        </span>
    </h2>

    {% if bridge_count > 0 %}
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-border">
            <thead class="bg-table-head">
                <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                        Bridge Name
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                        Network Name
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                        Connected Nodes
                    </th>
                </tr>
            </thead>
            <tbody class="bg-card divide-y divide-border">
                {% for bridge in bridges %}
                <tr class="hover:bg-hover transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-heading font-mono">
                        {{ bridge.bridge_name }}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-body font-mono">
                        {{ bridge.network_name }}
                    </td>
                    <td class="px-6 py-4 text-sm text-body">
                        {{ bridge.connected_nodes.join(", ") }}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <p class="text-center text-muted py-8 italic">No bridges configured in this lab.</p>
    {% endif %}
</div>

<!-- Actions -->
<div class="mt-6 flex items-start space-x-4">
    <a href="/labs" class="btn-cancel">
        Back to Labs
    </a>
    {% match lab_state %}
        {% when LabState::Running %}
        <button
            id="lab-stop-btn"
            onclick="labDetailAction('{{ lab_info.id }}', 'stop', this)"
            class="btn-danger cursor-pointer"
        >
            Stop Lab
        </button>
        {% when LabState::Partial %}
        <button
            id="lab-start-btn"
            onclick="labDetailAction('{{ lab_info.id }}', 'start', this)"
            class="btn-primary cursor-pointer"
        >
            Start Lab
        </button>
        <button
            id="lab-stop-btn"
            onclick="labDetailAction('{{ lab_info.id }}', 'stop', this)"
            class="btn-danger cursor-pointer"
        >
            Stop Lab
        </button>
        {% when LabState::Starting %}
        <button
            id="lab-stop-btn"
            onclick="labDetailAction('{{ lab_info.id }}', 'stop', this)"
            class="btn-danger cursor-pointer"
        >
            Stop Lab
        </button>
        {% else %}
        <button
            id="lab-start-btn"
            onclick="labDetailAction('{{ lab_info.id }}', 'start', this)"
            class="btn-primary cursor-pointer"
        >
            Start Lab
        </button>
    {% endmatch %}
    <div id="destroy-action">
        <button
            hx-get="/labs/{{ lab_info.id }}/destroy/confirm"
            hx-target="#destroy-action"
            hx-swap="innerHTML"
            class="btn-danger-outline cursor-pointer"
        >
            Destroy Lab
        </button>
    </div>
</div>

<!-- Action Result -->
<div id="lab-action-result" class="mt-4 hidden"></div>

<script src="/js/lab-actions.js"></script>
{% endblock %}
