{% extends "layouts/base.html.jinja" %}

{% block title %}Create Lab - Sherpa Labs{% endblock %}

{% block content %}
    <div class="space-y-6">
        <!-- Page Header -->
        <div class="flex items-center justify-between">
            <div>
                <h2 class="text-3xl font-bold text-heading">Create Lab</h2>
                <p class="mt-1 text-sm text-muted">Build a lab from scratch or upload an existing manifest</p>
            </div>
            <a href="/labs" class="px-4 py-2 text-sm font-medium text-body bg-card border border-border-strong rounded-lg hover:bg-hover transition-colors">
                Back to Labs
            </a>
        </div>

        <!-- Tabs -->
        <div class="border-b border-border">
            <nav class="flex space-x-6">
                <button id="tab-build" type="button" class="pb-3 text-sm font-medium border-b-2 border-accent text-accent transition-colors">
                    Build
                </button>
                <button id="tab-upload" type="button" class="pb-3 text-sm font-medium border-b-2 border-transparent text-muted hover:text-body transition-colors">
                    Import
                </button>
            </nav>
        </div>

        <!-- Form -->
        <form id="create-lab-form"
              hx-post="/labs/create"
              hx-target="#create-action"
              hx-swap="innerHTML">

            <input type="hidden" id="active-tab" value="build">
            <input type="hidden" id="manifest" name="manifest" value="">

            <!-- Build Panel -->
            <div id="panel-build" class="space-y-6">

                <!-- Lab Name -->
                <div class="bg-card rounded-lg shadow-sm border border-border p-6">
                    <h3 class="text-lg font-semibold text-heading mb-4">Lab Details</h3>
                    <div>
                        <label for="lab-name" class="block text-sm font-medium text-body mb-2">Name *</label>
                        <input type="text" id="lab-name" value="{{ generated_name }}" required
                            class="w-full max-w-md px-3 py-2 text-sm border border-border-strong rounded-md bg-card text-body focus:ring-accent focus:border-accent">
                        <p class="mt-1 text-xs text-muted">A unique name for this lab</p>
                    </div>
                </div>

                <!-- Nodes -->
                <div class="bg-card rounded-lg shadow-sm border border-border p-6">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-lg font-semibold text-heading">Nodes</h3>
                        <button type="button" id="add-node-btn"
                            class="px-3 py-1.5 text-sm font-medium text-accent border border-accent rounded-md hover:bg-accent hover:text-white transition-colors">
                            + Add Node
                        </button>
                    </div>
                    <div id="nodes-list" class="space-y-3">
                    </div>
                </div>

                <!-- Links -->
                <div class="bg-card rounded-lg shadow-sm border border-border p-6">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <h3 class="text-lg font-semibold text-heading">Links</h3>
                            <p class="text-xs text-muted mt-1">Point-to-point connections between node interfaces</p>
                        </div>
                        <button type="button" id="add-link-btn"
                            class="px-3 py-1.5 text-sm font-medium text-accent border border-accent rounded-md hover:bg-accent hover:text-white transition-colors">
                            + Add Link
                        </button>
                    </div>
                    <div id="links-list" class="space-y-3">
                    </div>
                    <p id="links-empty" class="text-sm text-muted py-4 text-center">No links configured. Click "Add Link" to connect node interfaces.</p>
                </div>

                <!-- Bridges -->
                <div class="bg-card rounded-lg shadow-sm border border-border p-6">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <h3 class="text-lg font-semibold text-heading">Bridges</h3>
                            <p class="text-xs text-muted mt-1">Shared broadcast domains connecting multiple node interfaces</p>
                        </div>
                        <button type="button" id="add-bridge-btn"
                            class="px-3 py-1.5 text-sm font-medium text-accent border border-accent rounded-md hover:bg-accent hover:text-white transition-colors">
                            + Add Bridge
                        </button>
                    </div>
                    <div id="bridges-list" class="space-y-3">
                    </div>
                    <p id="bridges-empty" class="text-sm text-muted py-4 text-center">No bridges configured. Click "Add Bridge" to create shared networks.</p>
                </div>
            </div>

            <!-- Upload Panel (hidden by default) -->
            <div id="panel-upload" class="hidden space-y-6">
                <div class="bg-card rounded-lg shadow-sm border border-border p-6">
                    <h3 class="text-lg font-semibold text-heading mb-4">Upload Manifest File</h3>
                    <div>
                        <label for="toml-file" class="block text-sm font-medium text-body mb-2">TOML File *</label>
                        <input type="file" id="toml-file" accept=".toml"
                            class="w-full px-3 py-2 border border-border-strong rounded-md bg-card text-body file:mr-4 file:py-1 file:px-3 file:rounded file:border-0 file:text-sm file:font-medium file:bg-accent file:text-white file:cursor-pointer hover:file:opacity-90">
                        <p class="mt-1 text-xs text-muted">Upload a manifest.toml file to create a lab</p>
                    </div>
                </div>
            </div>

            <!-- Submit -->
            <div class="flex items-center space-x-3 mt-6">
                <button type="submit"
                    class="px-6 py-3 text-sm font-medium text-white bg-accent rounded-lg hover:bg-accent-hover transition-colors">
                    Create Lab
                </button>
            </div>
        </form>

        <!-- Action target (progress/errors rendered here) -->
        <div id="create-action"></div>
    </div>

    <!-- Row templates cloned by JS — not rendered in the page -->
    <template id="tpl-node-row">
        <div class="flex items-start gap-3 p-3 bg-surface border border-border rounded-lg">
            <div class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="block text-xs font-medium text-muted mb-1">Name *</label>
                    <input type="text" data-field="node-name" required placeholder="e.g. dev01"
                        class="w-full px-3 py-2 text-sm border border-border-strong rounded-md bg-card text-body focus:ring-accent focus:border-accent">
                </div>
                <div>
                    <label class="block text-xs font-medium text-muted mb-1">Model *</label>
                    <select data-field="node-model" required
                        class="w-full px-3 py-2 text-sm border border-border-strong rounded-md bg-card text-body focus:ring-accent focus:border-accent">
                        <option value="">Select model...</option>
                        {% for model in models %}
                        <option value="{{ model }}">{{ model }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <button type="button" data-remove title="Remove node"
                class="mt-6 p-1.5 text-muted hover:text-danger-text rounded transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
    </template>

    <template id="tpl-link-row">
        <div class="flex items-start gap-3 p-3 bg-surface border border-border rounded-lg">
            <div class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="block text-xs font-medium text-muted mb-1">Source (node::interface) *</label>
                    <input type="text" data-field="link-src" required placeholder="e.g. dev01::eth1"
                        class="w-full px-3 py-2 text-sm border border-border-strong rounded-md bg-card text-body focus:ring-accent focus:border-accent">
                </div>
                <div>
                    <label class="block text-xs font-medium text-muted mb-1">Destination (node::interface) *</label>
                    <input type="text" data-field="link-dst" required placeholder="e.g. dev02::eth1"
                        class="w-full px-3 py-2 text-sm border border-border-strong rounded-md bg-card text-body focus:ring-accent focus:border-accent">
                </div>
            </div>
            <button type="button" data-remove title="Remove link"
                class="mt-6 p-1.5 text-muted hover:text-danger-text rounded transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
    </template>

    <template id="tpl-bridge-row">
        <div class="flex items-start gap-3 p-3 bg-surface border border-border rounded-lg">
            <div class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="block text-xs font-medium text-muted mb-1">Bridge Name *</label>
                    <input type="text" data-field="bridge-name" required placeholder="e.g. mgmt"
                        class="w-full px-3 py-2 text-sm border border-border-strong rounded-md bg-card text-body focus:ring-accent focus:border-accent">
                </div>
                <div>
                    <label class="block text-xs font-medium text-muted mb-1">Links (node::interface, comma-separated) *</label>
                    <input type="text" data-field="bridge-links" required placeholder="e.g. dev01::eth2, dev02::eth2"
                        class="w-full px-3 py-2 text-sm border border-border-strong rounded-md bg-card text-body focus:ring-accent focus:border-accent">
                </div>
            </div>
            <button type="button" data-remove title="Remove bridge"
                class="mt-6 p-1.5 text-muted hover:text-danger-text rounded transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
    </template>

    <script src="/js/lab-create.js"></script>
{% endblock %}
