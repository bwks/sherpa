{% extends "layouts/base.html.jinja" %}
{% import "macros/icons.html.jinja" as icons %}

{% block title %}Images - Sherpa Labs{% endblock %}


{% block content %}
<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-bold text-heading">Images</h2>
            <p class="mt-1 text-sm text-muted">Default device templates and their specifications</p>
        </div>
        <a href="/admin/images/upload" class="px-4 py-2 bg-accent hover:bg-accent-hover text-white text-sm font-medium rounded-md transition-colors">
            Upload Image
        </a>
    </div>

    <!-- Configs Table -->
    {% if !configs.is_empty() %}
    <div class="bg-card rounded-lg shadow-sm border border-border overflow-hidden">
        <table class="w-full bg-card border-collapse">
            <thead class="bg-table-head border-b border-border">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-table-head-text uppercase tracking-wide">Model</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-table-head-text uppercase tracking-wide">Kind</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-table-head-text uppercase tracking-wide">Version</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-table-head-text uppercase tracking-wide">CPU</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-table-head-text uppercase tracking-wide">Memory (MB)</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-table-head-text uppercase tracking-wide">Interfaces</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-table-head-text uppercase tracking-wide">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for config in configs %}
                <tr class="border-b border-border last:border-b-0 hover:bg-hover transition-colors">
                    <td class="p-4 text-sm text-body font-mono font-medium">{{ config.model }}</td>
                    <td class="p-4 text-sm text-center">
                        {% if config.kind == "virtual_machine" %}
                            <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full uppercase tracking-wide bg-kind-vm text-kind-vm-text">VM</span>
                        {% else if config.kind == "container" %}
                            <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full uppercase tracking-wide bg-kind-container text-kind-ctr-text">Container</span>
                        {% else if config.kind == "unikernel" %}
                            <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full uppercase tracking-wide bg-kind-unikernel text-kind-uni-text">Unikernel</span>
                        {% else %}
                            <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full uppercase tracking-wide">{{ config.kind }}</span>
                        {% endif %}
                    </td>
                    <td class="p-4 text-sm text-body">{{ config.version }}</td>
                    <td class="p-4 text-sm text-body text-center">{{ config.cpu_count }}</td>
                    <td class="p-4 text-sm text-body text-center">{{ config.memory }}</td>
                    <td class="p-4 text-sm text-body text-center">{{ config.data_interface_count }}</td>
                    <td class="p-4 text-sm text-body text-right">
                        <div class="flex items-center justify-end space-x-3">
                            <a href="/admin/images/{{ config.model }}" class="text-muted hover:text-heading transition-colors" title="View">
                                {% call icons::eye() %}
                            </a>
                            <a href="/admin/images/{{ config.model }}/edit" class="text-edit hover:text-edit-hover transition-colors" title="Edit">
                                {% call icons::pencil() %}
                            </a>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="bg-card rounded-lg shadow-sm border border-border overflow-hidden">
        <table class="w-full bg-card border-collapse">
            <thead class="bg-table-head border-b border-border">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-table-head-text uppercase tracking-wide">Model</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-table-head-text uppercase tracking-wide">Kind</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-table-head-text uppercase tracking-wide">Version</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-table-head-text uppercase tracking-wide">CPU</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-table-head-text uppercase tracking-wide">Memory (MB)</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-table-head-text uppercase tracking-wide">Interfaces</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-table-head-text uppercase tracking-wide">Actions</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
    {% endif %}
</div>
{% endblock %}
