{% extends "layout/base.html.jinja" %}

{% block title %}Node Images - Sherpa Labs{% endblock %}

{% block header_actions %}
    {% include "admin/partials/header-nav.html.jinja" %}
{% endblock %}

{% block content %}
<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-bold text-gray-900">Node Images</h2>
            <p class="mt-1 text-sm text-gray-600">Default device templates and their specifications</p>
        </div>
    </div>

    <!-- Configs Table -->
    {% if !configs.is_empty() %}
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <table class="w-full bg-white border-collapse">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Model</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">Kind</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Version</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">CPU</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">Memory (MB)</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">Interfaces</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for config in configs %}
                <tr class="border-b border-gray-200 last:border-b-0 hover:bg-gray-50 transition-colors">
                    <td class="p-4 text-sm text-gray-700 font-mono font-medium">{{ config.model }}</td>
                    <td class="p-4 text-sm text-center">
                        {% if config.kind == "virtual_machine" %}
                            <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full uppercase tracking-wide bg-blue-100 text-blue-800">VM</span>
                        {% else if config.kind == "container" %}
                            <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full uppercase tracking-wide bg-green-100 text-green-800">Container</span>
                        {% else if config.kind == "unikernel" %}
                            <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full uppercase tracking-wide bg-purple-100 text-purple-800">Unikernel</span>
                        {% else %}
                            <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full uppercase tracking-wide">{{ config.kind }}</span>
                        {% endif %}
                    </td>
                    <td class="p-4 text-sm text-gray-700">{{ config.version }}</td>
                    <td class="p-4 text-sm text-gray-700 text-center">{{ config.cpu_count }}</td>
                    <td class="p-4 text-sm text-gray-700 text-center">{{ config.memory }}</td>
                    <td class="p-4 text-sm text-gray-700 text-center">{{ config.data_interface_count }}</td>
                    <td class="p-4 text-sm text-gray-700 text-right">
                        <div class="flex items-center justify-end space-x-2">
                            <a href="/admin/node-images/{{ config.model }}/edit" class="inline-block px-3 py-1 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded transition-colors">
                                Edit
                            </a>
                            <a href="/admin/node-images/{{ config.model }}" class="inline-block px-3 py-1 text-sm font-medium text-white bg-gray-600 hover:bg-gray-700 rounded transition-colors">
                                View
                            </a>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <table class="w-full bg-white border-collapse">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Model</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">Kind</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Version</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">CPU</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">Memory (MB)</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">Interfaces</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide">Actions</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
    {% endif %}
</div>
{% endblock %}
