{% extends "layouts/base.html.jinja" %}
{% import "macros/icons.html.jinja" as icons %}

{% block title %}Admin Users - Sherpa Labs{% endblock %}


{% block content %}
<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-bold text-heading">User Management</h2>
            <p class="mt-1 text-sm text-muted">Manage user accounts, passwords, and SSH keys</p>
        </div>
    </div>

    <!-- Users Table -->
    {% if !users.is_empty() %}
    <div class="bg-card rounded-lg shadow-sm border border-border overflow-hidden">
        <table class="w-full bg-card border-collapse">
            <thead class="bg-table-head border-b border-border">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-table-head-text uppercase tracking-wide">Username</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-table-head-text uppercase tracking-wide">Admin</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-table-head-text uppercase tracking-wide">SSH Keys</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-table-head-text uppercase tracking-wide">Labs</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-table-head-text uppercase tracking-wide">Created</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-table-head-text uppercase tracking-wide">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr class="border-b border-border last:border-b-0 hover:bg-hover transition-colors">
                    <td class="p-4 text-sm text-body font-mono font-medium">{{ user.username }}</td>
                    <td class="p-4 text-sm text-center">
                        {% if user.is_admin %}
                            <span class="text-success-text text-xl">&#10003;</span>
                        {% else %}
                            <span class="text-subtle text-xl">&#8722;</span>
                        {% endif %}
                    </td>
                    <td class="p-4 text-sm text-body text-center">{{ user.ssh_key_count }}</td>
                    <td class="p-4 text-sm text-body text-center">{{ user.lab_count }}</td>
                    <td class="p-4 text-sm text-body text-right">{{ user.created_at_formatted }}</td>
                    <td class="p-4 text-sm text-body text-right">
                        <div class="flex items-center justify-end space-x-3">
                            <a href="/admin/users/{{ user.username }}" class="text-edit hover:text-edit-hover transition-colors" title="Edit">
                                {% call icons::pencil() %}
                            </a>
                            <button
                                hx-delete="/admin/users/{{ user.username }}"
                                hx-confirm="Are you sure you want to delete user '{{ user.username }}'? This action cannot be undone."
                                hx-target="closest tr"
                                hx-swap="outerHTML swap:0.5s"
                                class="text-danger-solid hover:text-danger-solid-hover transition-colors cursor-pointer" title="Delete"
                            >
                                {% call icons::trash() %}
                            </button>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="bg-card rounded-lg shadow-sm border border-border p-12 text-center">
        <p class="text-muted">No users found in the system.</p>
    </div>
    {% endif %}
</div>
{% endblock %}
