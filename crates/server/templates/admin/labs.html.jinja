{% extends "layouts/base.html.jinja" %}
{% import "macros/icons.html.jinja" as icons %}

{% block title %}Lab Management - Sherpa Labs{% endblock %}


{% block content %}
<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-bold text-heading">Lab Management</h2>
            <p class="mt-1 text-sm text-muted">View all labs across all users</p>
        </div>
    </div>

    <!-- Labs Table -->
    {% if !labs.is_empty() %}
    <div class="bg-card rounded-lg shadow-sm border border-border overflow-hidden">
        <table class="w-full bg-card border-collapse">
            <thead class="bg-table-head border-b border-border">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-table-head-text uppercase tracking-wide">Name</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-table-head-text uppercase tracking-wide">Lab ID</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-table-head-text uppercase tracking-wide">Owner</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-table-head-text uppercase tracking-wide">Nodes</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-table-head-text uppercase tracking-wide">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for lab in labs %}
                <tr class="border-b border-border last:border-b-0 hover:bg-hover transition-colors">
                    <td class="p-4 text-sm text-body font-mono font-medium">{{ lab.name }}</td>
                    <td class="p-4 text-sm text-body">{{ lab.lab_id }}</td>
                    <td class="p-4 text-sm text-body">{{ lab.owner_username }}</td>
                    <td class="p-4 text-sm text-body text-center">{{ lab.node_count }}</td>
                    <td class="p-4 text-sm text-body">
                        <div class="flex justify-end">
                            <a href="/labs/{{ lab.lab_id }}" class="text-muted hover:text-heading transition-colors" title="View">
                                {% call icons::eye() %}
                            </a>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="bg-card rounded-lg shadow-sm border border-border p-12 text-center">
        <p class="text-muted">No labs found in the system.</p>
    </div>
    {% endif %}
</div>
{% endblock %}
