{% extends "layout/base.html.jinja" %}

{% block title %}Lab Management - Sherpa Labs{% endblock %}

{% block header_actions %}
    {% include "admin/partials/header-nav.html.jinja" %}
{% endblock %}

{% block content %}
<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100">Lab Management</h2>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">View all labs across all users</p>
        </div>
    </div>

    <!-- Labs Table -->
    {% if !labs.is_empty() %}
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
        <table class="w-full bg-white dark:bg-gray-800 border-collapse">
            <thead class="bg-gray-50 dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Name</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Lab ID</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Owner</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Nodes</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for lab in labs %}
                <tr class="border-b border-gray-200 dark:border-gray-700 last:border-b-0 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                    <td class="p-4 text-sm text-gray-700 dark:text-gray-300 font-mono font-medium">{{ lab.name }}</td>
                    <td class="p-4 text-sm text-gray-700 dark:text-gray-300">{{ lab.lab_id }}</td>
                    <td class="p-4 text-sm text-gray-700 dark:text-gray-300">{{ lab.owner_username }}</td>
                    <td class="p-4 text-sm text-gray-700 dark:text-gray-300 text-center">{{ lab.node_count }}</td>
                    <td class="p-4 text-sm text-gray-700 dark:text-gray-300 text-right">
                        <a href="/labs/{{ lab.lab_id }}" class="inline-block px-3 py-1 text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 hover:bg-blue-50 rounded transition-colors">
                            View
                        </a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-12 text-center">
        <p class="text-gray-500 dark:text-gray-400">No labs found in the system.</p>
    </div>
    {% endif %}
</div>
{% endblock %}
