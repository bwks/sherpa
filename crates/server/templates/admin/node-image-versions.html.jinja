{% extends "layouts/base.html.jinja" %}
{% import "macros/icons.html.jinja" as icons %}

{% block title %}Versions: {{ model }} ({{ kind }}) - Sherpa Labs{% endblock %}


{% block content %}
<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-bold text-heading">Configuration Versions</h2>
            <p class="mt-1 text-sm text-muted">
                All versions for <span class="font-semibold">{{ model }}</span>
                {% let kind_str = kind.clone() %}
                {% if kind_str == "virtual_machine" %}
                    (Virtual Machine)
                {% else if kind_str == "container" %}
                    (Container)
                {% else if kind_str == "unikernel" %}
                    (Unikernel)
                {% else %}
                    ({{ kind }})
                {% endif %}
            </p>
        </div>
        <div class="flex items-center space-x-3">
            <a href="/admin/node-images" class="inline-block px-4 py-2 text-sm font-medium text-muted hover:text-heading hover:bg-hover rounded transition-colors">
                ← Back to List
            </a>
        </div>
    </div>

    <!-- Versions Table -->
    <div class="bg-card rounded-lg shadow-sm border border-border overflow-hidden">
        {% if versions.is_empty() %}
        <div class="text-center py-12">
            <p class="text-muted">No versions found for this configuration.</p>
        </div>
        {% else %}
        <table class="min-w-full divide-y divide-border">
            <thead class="bg-table-head">
                <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                        Version
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                        Default
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                        CPU
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                        Memory
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-table-head-text uppercase tracking-wider">
                        OS Variant
                    </th>
                    <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-table-head-text uppercase tracking-wider">
                        Actions
                    </th>
                </tr>
            </thead>
            <tbody class="bg-card divide-y divide-border">
                {% for config in versions %}
                <tr class="hover:bg-hover transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="text-sm font-medium text-heading">{{ config.version }}</span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        {% if config.default %}
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-success text-success-text">
                            Default
                        </span>
                        {% else %}
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-neutral-badge text-neutral-badge-text">
                            -
                        </span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-body">
                        {{ config.cpu_count }} cores
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-body">
                        {{ config.memory }} MB
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-body">
                        {{ config.os_variant }}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                        <div class="flex items-center justify-end space-x-3">
                            <a href="/admin/node-images/{{ config.model }}/{{ config.version }}" class="text-muted hover:text-heading transition-colors" title="View">
                                {% call icons::eye() %}
                            </a>
                            <a href="/admin/node-images/{{ config.model }}/{{ config.version }}/edit" class="text-edit hover:text-edit-hover transition-colors" title="Edit">
                                {% call icons::pencil() %}
                            </a>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% endif %}
    </div>

    <!-- Info Box -->
    <div class="bg-accent-light border border-info-border rounded-lg p-4">
        <div class="flex">
            <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-subtle" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                </svg>
            </div>
            <div class="ml-3">
                <h3 class="text-sm font-medium text-accent-lt-txt">About Versions</h3>
                <div class="mt-2 text-sm text-info-text">
                    <p>Versions are sorted by creation date (newest first). Only one version can be marked as default at a time.</p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
