<div id="admin-ssh-keys-list" class="flex flex-col gap-3 mt-6">
    {% if !success_message.is_empty() %}
    <div class="p-4 rounded-md mb-4 text-sm font-medium {% if is_error %}bg-red-50 dark:bg-red-900/40 text-red-800 dark:text-red-300 border border-red-200 dark:border-red-700{% else %}bg-green-50 dark:bg-green-900/40 text-green-800 dark:text-green-300 border border-green-200 dark:border-green-700{% endif %}">
        {{ success_message }}
    </div>
    {% endif %}

    {% if !ssh_keys.is_empty() %}
        {% for key in ssh_keys %}
        <div class="flex items-center justify-between gap-4 p-4 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-md">
            <div class="flex-1 overflow-hidden">
                <code class="block font-mono text-xs text-gray-700 dark:text-gray-300 whitespace-nowrap overflow-hidden text-ellipsis bg-white dark:bg-gray-800 p-2 rounded border border-gray-200 dark:border-gray-600">{{ key }}</code>
            </div>
            <form
                hx-delete="/admin/users/{{ target_username }}/ssh-keys/{{ loop.index0 }}"
                hx-target="#admin-ssh-keys-list"
                hx-swap="outerHTML"
                hx-confirm="Are you sure you want to delete this SSH key?"
                class="inline"
            >
                <button type="submit" class="px-3.5 py-1.5 text-xs font-medium text-white bg-red-600 rounded-md hover:bg-red-700 cursor-pointer active:scale-[0.98] transition-all">Delete</button>
            </form>
        </div>
        {% endfor %}
    {% else %}
        <p class="text-center text-gray-500 dark:text-gray-400 text-sm py-8 bg-gray-50 dark:bg-gray-700 rounded-md mt-4">No SSH keys configured for this user.</p>
    {% endif %}
</div>
