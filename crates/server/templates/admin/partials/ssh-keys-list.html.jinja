<div id="admin-ssh-keys-list" class="flex flex-col gap-3 mt-6">
    {% if !success_message.is_empty() %}
    <div class="p-4 rounded-md mb-4 text-sm font-medium {% if is_error %}bg-alert-error text-alert-error-text border border-alert-error-border{% else %}bg-alert-success text-alert-success-text border border-alert-success-border{% endif %}">
        {{ success_message }}
    </div>
    {% endif %}

    {% if !ssh_keys.is_empty() %}
        {% for key in ssh_keys %}
        <div class="flex items-center justify-between gap-4 p-4 bg-surface border border-border-strong rounded-md">
            <div class="flex-1 overflow-hidden">
                <code class="block font-mono text-xs text-body whitespace-nowrap overflow-hidden text-ellipsis bg-card p-2 rounded border border-border-strong">{{ key }}</code>
            </div>
            <form
                hx-delete="/admin/users/{{ target_username }}/ssh-keys/{{ loop.index0 }}"
                hx-target="#admin-ssh-keys-list"
                hx-swap="outerHTML"
                hx-confirm="Are you sure you want to delete this SSH key?"
                class="inline"
            >
                <button type="submit" class="px-3.5 py-1.5 text-xs font-medium text-white bg-danger-solid rounded-md hover:bg-danger-solid-hover cursor-pointer active:scale-[0.98] transition-all">Delete</button>
            </form>
        </div>
        {% endfor %}
    {% else %}
        <p class="text-center text-muted text-sm py-8 bg-surface rounded-md mt-4">No SSH keys configured for this user.</p>
    {% endif %}
</div>
