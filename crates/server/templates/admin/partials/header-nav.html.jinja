    <div class="flex items-center space-x-4">
        <a href="/admin/users" class="text-sm font-semibold text-header-link hover:text-header-link-hover transition-colors">
            Admin
        </a>
        <a href="/admin/labs" class="text-sm font-semibold text-header-link hover:text-header-link-hover transition-colors">
            Labs
        </a>
        <a href="/admin/images" class="text-sm font-semibold text-header-link hover:text-header-link-hover transition-colors">
            Images
        </a>
        <a href="/profile" class="text-sm font-semibold text-header-link hover:text-header-link-hover transition-colors">
            {{ username }}
        </a>
        <select onchange="setPalette(this.value)" class="palette-selector text-xs bg-header border border-header-border text-header-text rounded px-1 py-0.5 cursor-pointer">
            <option value="theme-zinc-emerald">Zinc Emerald</option>
            <option value="theme-stone-amber">Stone Amber</option>
            <option value="theme-neon-cyber">Neon Cyber</option>
            <option value="theme-matrix">Matrix</option>
            <option value="theme-retro-nes">Retro NES</option>
            <option value="theme-pixel-quest">Pixel Quest</option>
            <option value="theme-c64">Commodore 64</option>
            <option value="theme-ctp-latte">Catppuccin Latte</option>
            <option value="theme-ctp-frappe">Catppuccin Frappé</option>
            <option value="theme-ctp-macchiato">Catppuccin Macchiato</option>
            <option value="theme-ctp-mocha">Catppuccin Mocha</option>
            <option value="theme-gruvbox">Gruvbox</option>
            <option value="theme-sodapop">Sodapop</option>
            <option value="theme-nord">Nord</option>
            <option value="theme-rose-pine">Rosé Pine</option>
            <option value="theme-rose-pine-moon">Rosé Pine Moon</option>
            <option value="theme-rose-pine-dawn">Rosé Pine Dawn</option>
            <option value="theme-tokyo-night">Tokyo Night</option>
            <option value="theme-tokyo-storm">Tokyo Night Storm</option>
            <option value="theme-dracula">Dracula</option>
            <option value="theme-ant-bloody">Ant Bloody</option>
        </select>
        <button onclick="toggleTheme()" class="text-muted hover:text-heading cursor-pointer transition-colors" title="Toggle dark mode">
            <!-- Sun icon (shown in dark mode) -->
            <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
            <!-- Moon icon (shown in light mode) -->
            <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
            </svg>
        </button>
        <form action="/logout" method="post" class="inline">
            <button type="submit" class="text-sm font-semibold text-danger-text hover:opacity-80 cursor-pointer transition-colors">
                Logout
            </button>
        </form>
    </div>
