{% extends "layout/base.html.jinja" %}

{% block title %}Admin Dashboard - Sherpa Labs{% endblock %}

{% block header_actions %}
    {% include "admin/partials/header-nav.html.jinja" %}
{% endblock %}

{% block content %}
<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-bold text-gray-900">User Management</h2>
            <p class="mt-1 text-sm text-gray-600">Manage user accounts, passwords, and SSH keys</p>
        </div>
    </div>

    <!-- Users Table -->
    {% if !users.is_empty() %}
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <table class="w-full bg-white border-collapse">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Username</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">Admin</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">SSH Keys</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">Labs</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide">Created</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr class="border-b border-gray-200 last:border-b-0 hover:bg-gray-50 transition-colors">
                    <td class="p-4 text-sm text-gray-700 font-mono font-medium">{{ user.username }}</td>
                    <td class="p-4 text-sm text-center">
                        {% if user.is_admin %}
                            <span class="text-emerald-600 text-xl">✓</span>
                        {% else %}
                            <span class="text-gray-400 text-xl">−</span>
                        {% endif %}
                    </td>
                    <td class="p-4 text-sm text-gray-700 text-center">{{ user.ssh_key_count }}</td>
                    <td class="p-4 text-sm text-gray-700 text-center">{{ user.lab_count }}</td>
                    <td class="p-4 text-sm text-gray-700 text-right">{{ user.created_at_formatted }}</td>
                    <td class="p-4 text-sm text-gray-700 text-right">
                        <div class="flex items-center justify-end space-x-2">
                            <a href="/admin/users/{{ user.username }}" class="inline-block px-3 py-1 text-sm font-medium text-blue-600 hover:text-blue-800 hover:bg-blue-50 rounded transition-colors">
                                Edit
                            </a>
                            <button
                                hx-delete="/admin/users/{{ user.username }}"
                                hx-confirm="Are you sure you want to delete user '{{ user.username }}'? This action cannot be undone."
                                hx-target="closest tr"
                                hx-swap="outerHTML swap:0.5s"
                                class="inline-block px-3 py-1 text-sm font-medium text-red-600 hover:text-red-800 hover:bg-red-50 rounded transition-colors"
                            >
                                Delete
                            </button>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-12 text-center">
        <p class="text-gray-500">No users found in the system.</p>
    </div>
    {% endif %}
</div>
{% endblock %}
