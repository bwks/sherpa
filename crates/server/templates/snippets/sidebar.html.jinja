<aside class="fixed top-0 left-0 h-screen w-60 bg-header flex flex-col border-r border-header-border z-50">
    <!-- Logo -->
    <div class="flex items-center space-x-3 px-5 py-5">
        <div class="w-9 h-9 bg-gradient-to-br from-logo-from to-logo-to rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-lg">S</span>
        </div>
        <span class="text-lg font-bold text-header-text">Sherpa Labs</span>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
        <!-- Dashboard -->
        {% if active_page == "dashboard" %}
        <a href="/" class="flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors bg-accent/15 text-accent">
        {% else %}
        <a href="/" class="flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors text-header-link hover:text-header-link-hover hover:bg-white/5">
        {% endif %}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z"/>
            </svg>
            <span>Dashboard</span>
        </a>

        <!-- Labs -->
        {% if active_page == "labs" %}
        <a href="/labs" class="flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors bg-accent/15 text-accent">
        {% else %}
        <a href="/labs" class="flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors text-header-link hover:text-header-link-hover hover:bg-white/5">
        {% endif %}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
            </svg>
            <span>Labs</span>
        </a>

        {% if is_admin %}
        <!-- Admin Section -->
        <div class="pt-4 pb-1 px-3">
            <p class="text-xs font-semibold uppercase tracking-wider text-subtle">Admin</p>
        </div>

         <!-- Images -->
        {% if active_page == "admin_images" %}
        <a href="/admin/images" class="flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors bg-accent/15 text-accent">
        {% else %}
        <a href="/admin/images" class="flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors text-header-link hover:text-header-link-hover hover:bg-white/5">
        {% endif %}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/>
            </svg>
            <span>Images</span>
        </a>

        <!-- Labs -->
        {% if active_page == "admin_labs" %}
        <a href="/admin/labs" class="flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors bg-accent/15 text-accent">
        {% else %}
        <a href="/admin/labs" class="flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors text-header-link hover:text-header-link-hover hover:bg-white/5">
        {% endif %}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
            </svg>
            <span>Labs</span>
        </a>

       <!-- Users -->
        {% if active_page == "admin_users" %}
        <a href="/admin/users" class="flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors bg-accent/15 text-accent">
        {% else %}
        <a href="/admin/users" class="flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors text-header-link hover:text-header-link-hover hover:bg-white/5">
        {% endif %}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
            <span>Users</span>
        </a>

        <!-- Tools -->
        {% if active_page == "admin_tools" %}
        <a href="/admin/tools" class="flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors bg-accent/15 text-accent">
        {% else %}
        <a href="/admin/tools" class="flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors text-header-link hover:text-header-link-hover hover:bg-white/5">
        {% endif %}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span>Tools</span>
        </a>
        {% endif %}
    </nav>

    <!-- Bottom Section -->
    <div class="border-t border-header-border px-3 py-4 space-y-3">
        <!-- Theme Controls -->
        <div class="flex items-center justify-between px-3">
            <select onchange="setPalette(this.value)" class="palette-selector text-xs bg-header border border-header-border text-header-text rounded px-1.5 py-1 cursor-pointer">
                <option value="theme-zinc-emerald">Zinc Emerald</option>
                <option value="theme-stone-amber">Stone Amber</option>
                <option value="theme-neon-cyber">Neon Cyber</option>
                <option value="theme-matrix">Matrix</option>
                <option value="theme-retro-nes">Retro NES</option>
                <option value="theme-pixel-quest">Pixel Quest</option>
                <option value="theme-c64">Commodore 64</option>
                <option value="theme-ctp-latte">Catppuccin Latte</option>
                <option value="theme-ctp-frappe">Catppuccin Frappé</option>
                <option value="theme-ctp-macchiato">Catppuccin Macchiato</option>
                <option value="theme-ctp-mocha">Catppuccin Mocha</option>
                <option value="theme-gruvbox">Gruvbox</option>
                <option value="theme-fizzy">Fizzy</option>
                <option value="theme-nord">Nord</option>
                <option value="theme-rose-pine">Rosé Pine</option>
                <option value="theme-rose-pine-moon">Rosé Pine Moon</option>
                <option value="theme-rose-pine-dawn">Rosé Pine Dawn</option>
                <option value="theme-tokyo-night">Tokyo Night</option>
                <option value="theme-tokyo-storm">Tokyo Night Storm</option>
                <option value="theme-dracula">Dracula</option>
                <option value="theme-ant-bloody">Ant Bloody</option>
            </select>
            <button onclick="toggleTheme()" class="text-muted hover:text-heading cursor-pointer transition-colors" title="Toggle dark mode">
                <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
                </svg>
                <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                </svg>
            </button>
        </div>

        <!-- User Info & Logout -->
        <div class="flex items-center justify-between px-3">
            <a href="/profile" class="flex items-center space-x-2 min-w-0 hover:opacity-80 transition-opacity" title="Profile">
                <div class="w-7 h-7 rounded-full bg-accent/20 flex items-center justify-center flex-shrink-0">
                    <span class="text-xs font-semibold text-accent">{{ username|initial }}</span>
                </div>
                <span class="text-sm text-header-text truncate">{{ username }}</span>
            </a>
            <form action="/logout" method="post" class="inline flex-shrink-0">
                <button type="submit" class="text-subtle hover:text-danger-text cursor-pointer transition-colors" title="Logout">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                    </svg>
                </button>
            </form>
        </div>
    </div>
</aside>
