# Logging
log-queries
log-dhcp
log-facility=/var/log/dnsmasq.log

port=53
server={{ gateway_ipv4 }}
domain={{ SHERPA_DOMAIN_NAME }}

# DHCP
dhcp-leasefile=/opt/{{ ZTP_DIR }}/{{ DNSMASQ_DIR }}/{{ DNSMASQ_LEASES_FILE }}

# DHCP range for the subnet
dhcp-range={{ dhcp_start }},{{ dhcp_end }},2m

# Set default gateway (Option 3) and option 150 (TFTP server IP)
dhcp-option=3,{{ gateway_ipv4 }} # Default Gateway
dhcp-option=6,{{ tftp_server_ipv4 }} # DNS Server
dhcp-option=15,{{ SHERPA_DOMAIN_NAME }} # Search Domain
dhcp-option=66,{{ tftp_server_ipv4 }} # TFTP Server
dhcp-option=150,{{ tftp_server_ipv4 }} # TFTP Server
{% if let Some(gw6) = gateway_ipv6 %}
# IPv6 DHCP (SLAAC + stateless DHCPv6)
dhcp-range=::,constructor:*,ra-stateless
{% endif %}
{%- if let Some(dns6) = dns_ipv6 %}
dhcp-option=option6:23,[{{ dns6 }}] # DHCPv6 DNS Server
{%- endif %}

# Ignore client identifier
dhcp-ignore-clid

# Enable TFTP
enable-tftp
tftp-root=/opt/{{ ZTP_DIR }}/{{ TFTP_DIR }}

{# Host level DNS/DHCP settings #}
{%- for record in ztp_records %}
# {{ record.node_name }}
host-record={{ record.node_name }},{{ record.ipv4_address }}
host-record={{ record.node_name }}.{{ SHERPA_DOMAIN_NAME }},{{ record.ipv4_address }}
{%-   if let Some(ipv6) = record.ipv6_address %}
host-record={{ record.node_name }},{{ ipv6 }}
host-record={{ record.node_name }}.{{ SHERPA_DOMAIN_NAME }},{{ ipv6 }}
{%-   endif %}
{%-   if !record.mac_address.is_empty() %}
dhcp-host={{ record.mac_address }},{{ record.ipv4_address }},{{ record.node_name }},,set:{{ record.node_name }}-tag
{%-     match record.ztp_method %}
{%-       when ZtpMethod::Tftp %}
dhcp-option=tag:{{ record.node_name }}-tag,67,{{ record.config_file }}
{%-       when ZtpMethod::Http %}
dhcp-option=tag:{{ record.node_name }}-tag,67,"http://{{ tftp_server_ipv4 }}:8080/{{ NODE_CONFIGS_DIR }}/{{ record.config_file }}"
dhcp-option=tag:{{ record.node_name }}-tag,239,"http://{{ tftp_server_ipv4 }}:8080/{{ NODE_CONFIGS_DIR }}/{{ record.config_file }}"
{%-       else %}
# Add as needed
{%-     endmatch  %}
{%-   endif %}
{%- endfor %}
{# END #}
