!
hostname {{ hostname }}
domain-name {{ dns.domain }}
{%- for server in dns.name_servers %}
ip dns server-address {{ server.ipv4_address }}
{%- endfor %}
user admin group administrators password plaintext {{ SHERPA_PASSWORD }}
user {{ user.username }} {% if user.sudo %} group administrators{% endif %}{% if let Some(password) = user.password %} password plaintext {{ password }}{% endif %}
user {{ user.username }} authorized-key {{ user.ssh_public_key.algorithm }} {{ user.ssh_public_key.key }}
!
ntp server pool.ntp.org minpoll 4 maxpoll 4 iburst
ntp enable
!
ssh server vrf mgmt
ssh sftp-server
vlan 1
interface mgmt
    no shutdown
    {%- if let Some(mgmt_ipv4_address) = mgmt_ipv4_address %}
    ip static {{ mgmt_ipv4_address }}/{{ mgmt_ipv4.prefix_length }}
    {%- else %}
    ip dhcp
    {%- endif %}
    {%- if let Some(mgmt_ipv6_address) = mgmt_ipv6_address %}{% if let Some(mgmt_ipv6) = mgmt_ipv6 %}
    ipv6 static {{ mgmt_ipv6_address }}/{{ mgmt_ipv6.prefix_length }}
    {%- endif %}{% endif %}
!
ip route 0.0.0.0/0 {{ mgmt_ipv4.first }}
{%- if let Some(mgmt_ipv6_address) = mgmt_ipv6_address %}{% if let Some(mgmt_ipv6) = mgmt_ipv6 %}
ipv6 route ::/0 {{ mgmt_ipv6.first }}
{%- endif %}{% endif %}
!
https-server vrf mgmt
!
lldp enable
!