{
  "name": "sherpa-remote",
  "displayName": "Sherpa Remote",
  "description": "Auto-connect to Sherpa devbox VMs via Remote-SSH",
  "version": "0.1.0",
  "publisher": "sherpa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bwks/sherpa"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:manifest.toml"
  ],
  "main": "./out/src/extension.js",
  "extensionDependencies": [
    "ms-vscode-remote.remote-ssh"
  ],
  "contributes": {
    "commands": [
      {
        "command": "sherpa.connectDevbox",
        "title": "Sherpa: Connect to Devbox"
      }
    ],
    "configuration": {
      "title": "Sherpa Remote",
      "properties": {
        "sherpa.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically prompt to connect when sherpa_ssh_config is detected"
        },
        "sherpa.remoteUser": {
          "type": "string",
          "default": "sherpa",
          "description": "SSH user on the devbox"
        },
        "sherpa.remotePath": {
          "type": "string",
          "default": "/home/sherpa",
          "description": "Remote folder to open on the devbox"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "test": "node --test out/test/suite/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5"
  }
}
